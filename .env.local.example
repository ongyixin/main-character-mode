# Copy this to .env.local and fill in your keys

# ─── Demo mode ────────────────────────────────────────────────────────────────
# true  → hardcoded mock data, no API keys needed (offline demo)
# false → live Gemini / Lyria / NanoBanana calls
NEXT_PUBLIC_DEMO_MODE=true

# ─── Gemini 2.0 Flash ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Lyria 2 (Vertex AI) ──────────────────────────────────────────────────────
# Endpoint: https://{LOCATION}-aiplatform.googleapis.com/v1/projects/{PROJECT_ID}/...
# Auth: short-lived Bearer token (refresh with: gcloud auth print-access-token)
# Note: Vertex Lyria does not support API key auth.
LYRIA_PROJECT_ID=your-gcp-project-id
LYRIA_LOCATION=us-central1
LYRIA_ACCESS_TOKEN=ya29.your_access_token_here

# ─── NanoBanana image generation ─────────────────────────────────────────────
NANOBANANA_API_KEY=your_nanobanana_api_key_here
