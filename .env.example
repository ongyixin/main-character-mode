# ─── Gemini 2.0 Flash ─────────────────────────────────────────────────────────
# Used for: scene understanding, dialogue generation, mission framing
GEMINI_API_KEY=

# ─── Lyria ────────────────────────────────────────────────────────────────────
# Used for: adaptive soundtrack generation
LYRIA_PROJECT_ID=
LYRIA_LOCATION=us-central1
# OAuth token from: gcloud auth print-access-token
LYRIA_ACCESS_TOKEN=

# ─── NanoBanana ───────────────────────────────────────────────────────────────
# Used for: character portraits, mission cards, episode poster
NANOBANANA_API_KEY=
NANOBANANA_API_URL=https://api.nanobanana.ai/v1

# ─── App ──────────────────────────────────────────────────────────────────────
# NODE_ENV is set automatically by Next.js
